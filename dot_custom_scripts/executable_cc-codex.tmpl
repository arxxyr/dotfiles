{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
set -euo pipefail

PROXY="${CODEX_PROXY:-http://127.0.0.1:10808}"

case "${1:-start}" in
kill)
pids=$(pgrep -x codex 2>/dev/null || true)
if [[ -z "$pids" ]]; then
echo "[OK] No codex processes running"
exit 0
fi
echo "Killing codex processes"
echo "  PIDs: $pids"
kill $pids 2>/dev/null || true
sleep 0.5
remaining=$(pgrep -x codex 2>/dev/null || true)
[[ -n "$remaining" ]] && kill -9 $remaining 2>/dev/null || true
echo "[OK] Done"
;;
start|"")
export HTTP_PROXY="$PROXY"
export HTTPS_PROXY="$PROXY"
export ALL_PROXY="$PROXY"
export NO_PROXY="localhost,127.0.0.1,::1,.local"
echo "Proxy: $PROXY"
exec codex --dangerously-bypass-approvals-and-sandbox
;;
*)
echo "Usage: cc-codex [start|kill]"
exit 1
;;
esac
{{ end -}}
