# ~/.config/shell/profile.sh — 共享环境变量，登录时加载一次
# 由 .profile (bash) 和 .zprofile (zsh) source

{{- if eq .chezmoi.os "darwin" }}

# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null)" || eval "$(/usr/local/bin/brew shellenv 2>/dev/null)"
{{- end }}

# rust/cargo
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# ruby/rbenv
export PATH="$HOME/.rbenv/bin:$PATH"

# rvm
export PATH="$HOME/.rvm/bin:$PATH"

# local bin
export PATH="$HOME/.local/bin:$PATH"

# NVM 目录（函数加载在 rc 文件中）
export NVM_DIR="$HOME/.nvm"

{{- if ne .chezmoi.os "darwin" }}

# goproxy
export GOPROXY=https://proxy.golang.com.cn,direct
{{- end }}

{{- if eq .chezmoi.os "linux" }}

# CUDA
export PATH="/usr/local/cuda/bin:$PATH"

# rviz2 QT 缩放
export QT_AUTO_SCREEN_SCALE_FACTOR=0
{{- end }}

# zig
export PATH="$HOME/env/zig:$PATH"

# xmake
[ -s "$HOME/.xmake/profile" ] && . "$HOME/.xmake/profile"

# uv
[ -f "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"

# 自定义脚本目录
case ":$PATH:" in
    *":$HOME/.custom_scripts:"*) ;;
    *) export PATH="$HOME/.custom_scripts:$PATH" ;;
esac

{{- if eq .chezmoi.os "darwin" }}

# node@24
export PATH="/opt/homebrew/opt/node@24/bin:$PATH"
{{- end }}

# core dump
ulimit -c unlimited

export SHELL_PROFILE_LOADED=1
