{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -e

# 安装 Homebrew（如果未安装）
if ! command -v brew &>/dev/null; then
    echo "[INSTALL] Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null)" || eval "$(/usr/local/bin/brew shellenv 2>/dev/null)"
else
    echo "[SKIP] Homebrew already installed"
fi

# 安装必要工具
PACKAGES=(
    zoxide
    bash-completion
    xmake
    connect
    proxychains-ng
    fzf
    ripgrep
    ranger
    btop
    jq
    wget
)

for pkg in "${PACKAGES[@]}"; do
    if brew list "$pkg" &>/dev/null; then
        echo "[SKIP] $pkg already installed"
    else
        echo "[INSTALL] $pkg..."
        brew install "$pkg"
    fi
done

# Neovim nightly（--HEAD 从 git 源码构建）
if brew list --head neovim &>/dev/null 2>&1; then
    echo "[SKIP] neovim (HEAD) already installed"
else
    echo "[INSTALL] neovim --HEAD..."
    brew install --HEAD neovim
fi

# Oh My Zsh
if [[ -d "$HOME/.oh-my-zsh" ]]; then
    echo "[SKIP] Oh My Zsh already installed"
else
    echo "[INSTALL] Oh My Zsh..."
    RUNZSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

# Zsh 插件（oh-my-zsh custom plugins）
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
ZSH_PLUGINS="
zsh-syntax-highlighting https://github.com/zsh-users/zsh-syntax-highlighting
zsh-autosuggestions https://github.com/zsh-users/zsh-autosuggestions
zsh-completions https://github.com/zsh-users/zsh-completions
"

echo "$ZSH_PLUGINS" | while read -r plugin url; do
    [[ -z "$plugin" ]] && continue
    if [[ -d "$ZSH_CUSTOM/plugins/$plugin" ]]; then
        echo "[SKIP] $plugin already installed"
    else
        echo "[INSTALL] $plugin..."
        git clone "$url" "$ZSH_CUSTOM/plugins/$plugin"
    fi
done

# chezmoi auto commit/push
mkdir -p ~/.config/chezmoi
if ! grep -q "autoCommit" ~/.config/chezmoi/chezmoi.toml 2>/dev/null; then
    cat >> ~/.config/chezmoi/chezmoi.toml << 'EOF'
[git]
    autoCommit = true
    autoPush = true
EOF
    echo "[OK] chezmoi auto commit/push enabled"
else
    echo "[SKIP] chezmoi already configured"
fi

echo "[DONE] macOS setup complete"
{{ end -}}
